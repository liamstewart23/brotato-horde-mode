{
	"name": "HordeMode",
	"namespace": "PapiLeem",
	"version_number": "1.1.0",
	"description": "Adds Horde Mode - a toggle on the difficulty selection page with 2x, 3x, 5x, or 10x enemy multipliers, kill counter HUD, and challenges.",
	"website_url": "",
	"dependencies": [],
	"extra": {
		"godot": {
			"incompatibilities": [],
			"optional_dependencies": [],
			"authors": [
				"PapiLeem"
			],
			"compatible_mod_loader_version": ["6.2.0"],
			"compatible_game_version": ["1.1.13.1"],
			"config_schema": {
				"type": "object",
				"properties": {
					"enemy_count_percent": {
						"type": "integer",
						"title": "Enemy Count Bonus (%)",
						"description": "Extra enemies spawned. 400 = 5x total",
						"default": 400,
						"minimum": 50,
						"maximum": 900
					},
					"enemy_hp_percent": {
						"type": "integer",
						"title": "Enemy HP Modifier (%)",
						"description": "Enemy health change. -15 = 85% HP",
						"default": -15,
						"minimum": -80,
						"maximum": 0
					},
					"enemy_damage_percent": {
						"type": "integer",
						"title": "Enemy Damage Modifier (%)",
						"description": "Enemy damage change. -10 = 90% damage",
						"default": -10,
						"minimum": -50,
						"maximum": 0
					},
					"enemy_speed_percent": {
						"type": "integer",
						"title": "Enemy Speed Modifier (%)",
						"description": "Enemy speed change. 20 = 120% speed",
						"default": 20,
						"minimum": 0,
						"maximum": 100
					},
					"materials_percent": {
						"type": "integer",
						"title": "Materials Drop Modifier (%)",
						"description": "Materials drop change. -50 = 50% drops",
						"default": -50,
						"minimum": -80,
						"maximum": 0
					},
					"xp_percent": {
						"type": "integer",
						"title": "XP Gain Modifier (%)",
						"description": "XP gain change. -50 = 50% XP",
						"default": -50,
						"minimum": -80,
						"maximum": 0
					},
					"max_enemies_multiplier": {
						"type": "number",
						"title": "Max Enemies Cap Multiplier",
						"description": "Multiplier for the max concurrent enemies cap",
						"default": 5.0,
						"minimum": 1.5,
						"maximum": 10.0
					}
				}
			},
			"tags": ["Gameplay"]
		}
	}
}
